NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=https://workout-app-seven-delta.vercel.app

# Server-only optional Gemini generation. Keep disabled unless a privacy-reviewed,
# billing-enabled Gemini API project is configured; never prefix these with NEXT_PUBLIC_.
AI_GENERATION_ENABLED=false
AI_GENERATION_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=12000
GEMINI_MAX_INPUT_CHARS=4000
GEMINI_MAX_OUTPUT_TOKENS=4096
GEMINI_API_KEY=
