NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=https://workout-app-seven-delta.vercel.app

# Server-only optional Gemini generation. Keep disabled until the committed quota
# migration is applied and verified; never prefix these with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
